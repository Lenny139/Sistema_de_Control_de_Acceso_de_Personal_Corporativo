{
  "info": {
    "name": "Parcial - Validación de Requerimientos (Control de Acceso)",
    "description": "Colección para validar requerimientos del parcial vía API (/api/1.0). Incluye setup de tokens/fixtures y pruebas automáticas de criterios funcionales y RBAC.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00 - Setup",
      "item": [
        {
          "name": "Init Dates",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const now = new Date();",
                  "const today = now.toISOString().slice(0, 10);",
                  "const yesterdayDate = new Date(now);",
                  "yesterdayDate.setDate(yesterdayDate.getDate() - 1);",
                  "const yesterday = yesterdayDate.toISOString().slice(0, 10);",
                  "pm.environment.set('today', today);",
                  "pm.environment.set('yesterday', yesterday);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Fechas inicializadas', function () {",
                  "  pm.expect(pm.environment.get('today')).to.be.a('string').and.not.empty;",
                  "  pm.expect(pm.environment.get('yesterday')).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/1.0/docs.json",
              "host": ["{{baseUrl}}"],
              "path": ["api", "1.0", "docs.json"]
            }
          }
        },
        {
          "name": "Login Guardia",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login guardia 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Token guardia guardado', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.environment.set('token_guardia', body.accessToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{guardia_username}}\",\n  \"password\": \"{{guardia_password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/1.0/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "1.0", "auth", "login"]
            }
          }
        },
        {
          "name": "Login Gerente",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login gerente 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Token gerente guardado', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.environment.set('token_gerente', body.accessToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{gerente_username}}\",\n  \"password\": \"{{gerente_password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/1.0/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "1.0", "auth", "login"]
            }
          }
        },
        {
          "name": "Get Fixture Employee (Gerente)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Listar empleados 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Empleado fixture seteado', function () {",
                  "  const data = pm.response.json();",
                  "  pm.expect(data).to.be.an('array').and.not.empty;",
                  "  pm.environment.set('empleado_id', data[0].id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_gerente}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/1.0/employees",
              "host": ["{{baseUrl}}"],
              "path": ["api", "1.0", "employees"]
            }
          }
        },
        {
          "name": "Get Fixture Checkpoint (Guardia)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Listar checkpoints 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Checkpoint fixture seteado', function () {",
                  "  const data = pm.response.json();",
                  "  pm.expect(data).to.be.an('array').and.not.empty;",
                  "  pm.environment.set('checkpoint_id', data[0].id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_guardia}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/1.0/checkpoints",
              "host": ["{{baseUrl}}"],
              "path": ["api", "1.0", "checkpoints"]
            }
          }
        },
        {
          "name": "Ensure Employee OUT (best-effort)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Estado inicial válido para continuar (201 o 409)', function () {",
                  "  pm.expect([201, 409]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_guardia}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"empleadoId\": \"{{empleado_id}}\",\n  \"puntoControlId\": \"{{checkpoint_id}}\",\n  \"observaciones\": \"setup ensure out\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/1.0/access-records/check-out",
              "host": ["{{baseUrl}}"],
              "path": ["api", "1.0", "access-records", "check-out"]
            }
          }
        }
      ]
    },
    {
      "name": "01 - Criterio 1 (Check-in + presentes + conflicto)",
      "item": [
        {
          "name": "C1 - Buscar empleado por ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Search 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Empleado aparece en resultados', function () {",
                  "  const data = pm.response.json();",
                  "  pm.expect(data).to.be.an('array');",
                  "  const found = data.some(function (item) { return item.id === pm.environment.get('empleado_id'); });",
                  "  pm.expect(found).to.eql(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_guardia}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/1.0/employees/search?q={{empleado_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "1.0", "employees", "search"],
              "query": [
                { "key": "q", "value": "{{empleado_id}}" }
              ]
            }
          }
        },
        {
          "name": "C1 - Check-in OK",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Check-in crea registro (201)', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Tipo ENTRADA', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.tipo).to.eql('ENTRADA');",
                  "});"
