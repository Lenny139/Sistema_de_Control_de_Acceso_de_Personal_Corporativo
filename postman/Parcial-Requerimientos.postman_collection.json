        {
          "name": "C6 - Swagger JSON contiene paths clave",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Docs JSON 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Paths críticos documentados', function () {",
                  "  const spec = pm.response.json();",
                  "  pm.expect(spec.paths).to.have.property('/api/1.0/auth/login');",
                  "  pm.expect(spec.paths).to.have.property('/api/1.0/access-records/check-in');",
                  "  pm.expect(spec.paths).to.have.property('/api/1.0/access-records/check-out');",
                  "  pm.expect(spec.paths).to.have.property('/api/1.0/reports/asistencia');",
                  "  pm.expect(spec.paths).to.have.property('/api/1.0/reports/puntualidad');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
