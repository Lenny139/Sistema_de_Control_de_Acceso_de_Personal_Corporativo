          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_guardia}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"empleadoId\": \"{{empleado_id}}\",\n  \"puntoControlId\": \"{{checkpoint_id}}\",\n  \"observaciones\": \"criterio 1 checkin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/1.0/access-records/check-in",
              "host": ["{{baseUrl}}"],
              "path": ["api", "1.0", "access-records", "check-in"]
            }
          }
        },
        {
          "name": "C1 - Dashboard presentes incluye empleado",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Presentes 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Empleado está presente', function () {",
                  "  const data = pm.response.json();",
                  "  pm.expect(data).to.be.an('array');",
                  "  const found = data.some(function (item) { return item.empleadoId === pm.environment.get('empleado_id'); });",
                  "  pm.expect(found).to.eql(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_guardia}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/1.0/access-records/presentes",
              "host": ["{{baseUrl}}"],
              "path": ["api", "1.0", "access-records", "presentes"]
            }
          }
        },
        {
          "name": "C1 - Segundo check-in devuelve 409",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Segundo check-in en conflicto', function () {",
                  "  pm.response.to.have.status(409);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_guardia}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"empleadoId\": \"{{empleado_id}}\",\n  \"puntoControlId\": \"{{checkpoint_id}}\",\n  \"observaciones\": \"criterio 1 conflicto\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/1.0/access-records/check-in",
              "host": ["{{baseUrl}}"],
              "path": ["api", "1.0", "access-records", "check-in"]
            }
          }
        }
      ]
