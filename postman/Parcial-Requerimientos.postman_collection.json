    {
      "name": "03 - Criterios 3 y 4 (Reportes)",
      "item": [
        {
          "name": "C3 - Reporte Asistencia (Gerente)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Reporte asistencia 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Estructura reporte asistencia válida', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.tipo).to.eql('ASISTENCIA');",
                  "  pm.expect(body.data).to.be.an('array');",
                  "});",
                  "pm.test('Modo estricto (opcional): horas esperadas 09:00-17:00', function () {",
                  "  const strict = pm.environment.get('strictReports') === 'true';",
                  "  if (!strict) {",
                  "    pm.expect(true).to.eql(true);",
                  "    return;",
                  "  }",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data.length).to.be.greaterThan(0);",
                  "  pm.expect(body.data[0].horaEntrada).to.eql('09:00');",
                  "  pm.expect(body.data[0].horaSalida).to.eql('17:00');",
                  "  pm.expect(Number(body.data[0].horasTrabajadas)).to.eql(8);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_gerente}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/1.0/reports/asistencia?empleadoId={{empleado_id}}&fechaInicio={{yesterday}}&fechaFin={{yesterday}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "1.0", "reports", "asistencia"],
              "query": [
                { "key": "empleadoId", "value": "{{empleado_id}}" },
                { "key": "fechaInicio", "value": "{{yesterday}}" },
                { "key": "fechaFin", "value": "{{yesterday}}" }
              ]
            }
          }
        },
        {
          "name": "C4 - Reporte Puntualidad (Gerente)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Reporte puntualidad 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Estructura reporte puntualidad válida', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.tipo).to.eql('PUNTUALIDAD');",
                  "  pm.expect(body.data).to.be.an('array');",
                  "});",
                  "pm.test('Modo estricto (opcional): TARDANZA 15 min', function () {",
                  "  const strict = pm.environment.get('strictReports') === 'true';",
                  "  if (!strict) {",
                  "    pm.expect(true).to.eql(true);",
                  "    return;",
                  "  }",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data.length).to.be.greaterThan(0);",
                  "  pm.expect(body.data[0].estadoPuntualidad).to.eql('TARDANZA');",
                  "  pm.expect(Number(body.data[0].minutosRetraso)).to.eql(15);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_gerente}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/1.0/reports/puntualidad?empleadoId={{empleado_id}}&fechaInicio={{today}}&fechaFin={{today}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "1.0", "reports", "puntualidad"],
              "query": [
                { "key": "empleadoId", "value": "{{empleado_id}}" },
                { "key": "fechaInicio", "value": "{{today}}" },
                { "key": "fechaFin", "value": "{{today}}" }
              ]
            }
          }
        }
      ]
